<Window x:Class="PasteSheet.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:PasteSheet.Presentation"
        Title="PasteSheet"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        ShowActivated="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <p:BoolToVisibilityConverter x:Key="BoolVis" />
        <p:BoolToVisibilityConverter x:Key="BoolVisInvert" Invert="True" />
        <p:ViewTypeVisibilityConverter x:Key="SettingsVis" />
        <p:ViewTypeVisibilityConverter x:Key="NotSettingsVis" Invert="True" />
        <p:StringEmptyToVisibilityConverter x:Key="EmptyVis" />
        <p:StringEmptyToVisibilityConverter x:Key="NotEmptyVis" Invert="True" />
        <p:ActionButtonBrushConverter x:Key="BtnBg" Background="True" />
        <p:ActionButtonBrushConverter x:Key="BtnFg" Background="False" />

        <SolidColorBrush x:Key="Bg" Color="#121212" />
        <SolidColorBrush x:Key="Panel" Color="#1A1A1A" />
        <SolidColorBrush x:Key="Accent" Color="#DCDC57" />
        <SolidColorBrush x:Key="SubText" Color="#68748D" />
        <SolidColorBrush x:Key="SubText40" Color="#6668748D" />
        <SolidColorBrush x:Key="Memo" Color="#E2E2B6" />
        <SolidColorBrush x:Key="Danger" Color="#FF4444" />
        <SolidColorBrush x:Key="Fg" Color="#EAEAEA" />
        <SolidColorBrush x:Key="White10" Color="#1AFFFFFF" />
        <SolidColorBrush x:Key="White08" Color="#14FFFFFF" />
        <SolidColorBrush x:Key="Content70" Color="#B3FFFFFF" />

        <!-- Borderless flat icon button -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inline action button (Paste / Edit / Delete) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource White10}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- List row container: stretch, no default selection chrome -->
        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer rounded window -->
    <Border Background="{StaticResource Bg}" CornerRadius="16"
            BorderBrush="#1AFFFFFF" BorderThickness="1">
        <Grid>
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="16,16,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Back button -->
                    <Button Grid.Column="0" Content="◀" FontSize="16" Margin="0,0,8,0"
                            Foreground="{StaticResource Accent}" Style="{StaticResource IconButton}"
                            Click="OnBackClick"
                            Visibility="{Binding ShowBack, Converter={StaticResource BoolVis}}" />

                    <!-- Title / search overlay -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource Accent}"
                                 FontSize="22" FontWeight="Medium" Padding="0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <!-- Hide the real caret while empty; the title overlay shows
                                         the blinking cursor instead. Show it once typing starts. -->
                                    <Setter Property="CaretBrush" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchQuery, Converter={StaticResource NotEmptyVis}}" Value="Visible">
                                            <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <!-- Title shown when no query; click passes through to the textbox -->
                        <StackPanel Orientation="Horizontal" IsHitTestVisible="False"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding SearchQuery, Converter={StaticResource EmptyVis}}">
                            <TextBlock Text="{Binding HeaderTitle}" Foreground="{StaticResource Accent}"
                                       FontSize="22" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="CursorBlink" Text="|" Foreground="{StaticResource Accent}"
                                       FontSize="22" FontWeight="Medium" />
                        </StackPanel>
                    </Grid>

                    <!-- Settings gear -->
                    <Button Grid.Column="2" Content="⚙" FontSize="20"
                            Foreground="#B3DCDC57" Style="{StaticResource IconButton}"
                            Click="OnSettingsClick"
                            Visibility="{Binding CurrentView, Converter={StaticResource NotSettingsVis}, ConverterParameter=Settings}" />
                </Grid>

                <!-- List -->
                <ListBox Grid.Row="1" x:Name="List" Margin="6,0"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemsSource="{Binding Rows}"
                         SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                         MouseDoubleClick="OnListDoubleClick"
                         Visibility="{Binding CurrentView, Converter={StaticResource NotSettingsVis}, ConverterParameter=Settings}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Padding="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Background" Value="#14DCDC57" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <!-- ============ Directory row ============ -->
                                    <Grid Margin="12" Visibility="{Binding IsDirectory, Converter={StaticResource BoolVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="4" Height="18" CornerRadius="2" Margin="0,0,12,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource SubText40}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Accent}" />
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#DCDC57" ShadowDepth="0" BlurRadius="8" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding DirectoryName}" FontSize="15"
                                                   Foreground="White" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="2" Background="{StaticResource White08}" CornerRadius="10"
                                                Padding="8,2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CountText}" FontSize="12"
                                                       Foreground="{StaticResource SubText}" />
                                        </Border>
                                    </Grid>

                                    <!-- ============ New folder / item row ============ -->
                                    <Border Margin="0" Visibility="{Binding IsNew, Converter={StaticResource BoolVis}}">
                                        <Border BorderBrush="#0DFFFFFF" BorderThickness="1" CornerRadius="6"
                                                Padding="12" SnapsToDevicePixels="True">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="＋" FontSize="18" FontWeight="Bold"
                                                           Foreground="{StaticResource Accent}" Margin="0,0,12,0" />
                                                <TextBlock Text="{Binding NewLabel}" FontSize="14"
                                                           Foreground="#CCDCDC57" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Border>

                                    <!-- ============ Item row ============ -->
                                    <Grid Margin="14,12" Visibility="{Binding IsItem, Converter={StaticResource BoolVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Accent bar -->
                                        <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,12,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource SubText40}" />
                                                    <Setter Property="Height" Value="16" />
                                                    <Setter Property="VerticalAlignment" Value="Top" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Accent}" />
                                                            <Setter Property="Height" Value="Auto" />
                                                            <Setter Property="VerticalAlignment" Value="Stretch" />
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect Color="#DCDC57" ShadowDepth="0" BlurRadius="8" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <!-- Memo + folder label -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Memo}" FontSize="13" FontWeight="Medium"
                                                           Foreground="{StaticResource Memo}" TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding HasMemo, Converter={StaticResource BoolVis}}" />
                                                <Border Grid.Column="1" Background="{StaticResource White08}" CornerRadius="4"
                                                        Padding="6,1" VerticalAlignment="Center"
                                                        Visibility="{Binding ShowFolderLabel, Converter={StaticResource BoolVis}}">
                                                    <TextBlock Text="{Binding FolderLabel}" FontSize="10"
                                                               Foreground="#66FFFFFF" />
                                                </Border>
                                            </Grid>

                                            <!-- Content -->
                                            <TextBlock Text="{Binding ContentOneLine}" FontSize="14" Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Content70}" />
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                        <Setter Property="TextWrapping" Value="NoWrap" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                <Setter Property="Foreground" Value="White" />
                                                                <Setter Property="TextTrimming" Value="None" />
                                                                <Setter Property="TextWrapping" Value="Wrap" />
                                                                <Setter Property="MaxHeight" Value="300" />
                                                                <Setter Property="Text" Value="{Binding Content}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Date + actions (selected only) -->
                                            <StackPanel Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding DateDisplay}" FontFamily="Consolas" FontSize="11"
                                                           Foreground="#9968748D" Margin="0,8,0,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Button Content="Paste" Style="{StaticResource ActionButton}" Margin="0,0,8,0"
                                                            Click="OnRowPaste"
                                                            Background="{Binding DataContext.ButtonFocusIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnBg}, ConverterParameter=0}"
                                                            Foreground="{Binding DataContext.ButtonFocusIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnFg}, ConverterParameter=0}" />
                                                    <Button Content="Edit" Style="{StaticResource ActionButton}" Margin="0,0,8,0"
                                                            Click="OnRowEdit"
                                                            Background="{Binding DataContext.ButtonFocusIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnBg}, ConverterParameter=1}"
                                                            Foreground="{Binding DataContext.ButtonFocusIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnFg}, ConverterParameter=1}" />
                                                    <Button Content="Delete" Style="{StaticResource ActionButton}"
                                                            Click="OnRowDelete"
                                                            Background="{Binding DataContext.ButtonFocusIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnBg}, ConverterParameter=2:danger}"
                                                            Foreground="{Binding DataContext.ButtonFocusIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BtnFg}, ConverterParameter=2:danger}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Bottom resize handle (cosmetic) -->
                <Border Grid.Row="2" Width="32" Height="3" CornerRadius="1.5" Margin="0,6,0,8"
                        Background="#26FFFFFF" HorizontalAlignment="Center"
                        Visibility="{Binding CurrentView, Converter={StaticResource NotSettingsVis}, ConverterParameter=Settings}" />
            </Grid>

            <!-- Settings panel -->
            <Border Background="{StaticResource Bg}" CornerRadius="16"
                    Visibility="{Binding CurrentView, Converter={StaticResource SettingsVis}, ConverterParameter=Settings}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,56,0,0">
                    <StackPanel Margin="16">
                        <TextBlock Text="GENERAL" Foreground="{StaticResource SubText}" FontSize="13"
                                   FontWeight="SemiBold" Margin="4,0,0,12" />
                        <Border Background="#08FFFFFF" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                            <CheckBox Content="Mouse Edge Detection" Foreground="{StaticResource Fg}"
                                      IsChecked="{Binding MouseEdgeEnabled, Mode=TwoWay}" />
                        </Border>
                        <Border Background="#08FFFFFF" CornerRadius="12" Padding="12">
                            <CheckBox Content="Launch at Login" Foreground="{StaticResource Fg}"
                                      IsChecked="{Binding AutoStartEnabled, Mode=TwoWay}" />
                        </Border>
                        <TextBlock Text="Toggle: Ctrl + Shift + V    •    Esc to go back"
                                   Foreground="{StaticResource SubText}" FontSize="11" Margin="4,16,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Detail overlay -->
            <Border Background="#CC000000" CornerRadius="16"
                    Visibility="{Binding HasDetail, Converter={StaticResource BoolVis}}">
                <Border Background="#1E1E1E" CornerRadius="8" Margin="24" Padding="16"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Item" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Border Background="#1A1A1A" CornerRadius="6" Padding="10" MaxHeight="300">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding DetailItem.Content}" Foreground="{StaticResource Fg}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Edit overlay -->
            <Border Background="#CC000000" CornerRadius="16"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolVis}}">
                <Border Background="#1E1E1E" CornerRadius="8" Margin="20" Padding="16" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Edit Item" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <Border Background="#0DDCDC57" CornerRadius="4" Padding="6" Margin="0,0,0,8"
                                BorderBrush="#33DCDC57" BorderThickness="1">
                            <TextBox x:Name="EditMemoBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource Accent}" FontSize="13" FontWeight="SemiBold"
                                     Text="{Binding EditMemo, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                        <Border Background="#08FFFFFF" CornerRadius="6" Padding="6"
                                BorderBrush="#33DCDC57" BorderThickness="1">
                            <TextBox x:Name="EditBox" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource Fg}" AcceptsReturn="True" MinHeight="120"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                        <TextBlock Text="Ctrl+Enter to save  •  Esc to cancel"
                                   Foreground="{StaticResource SubText}" FontSize="11" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Border>

            <!-- Modal overlay -->
            <Border Background="#CC000000" CornerRadius="16"
                    Visibility="{Binding HasModal, Converter={StaticResource BoolVis}}">
                <Border Background="#1E1E1E" CornerRadius="8" Margin="28" Padding="18" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{Binding Modal.Title}" Foreground="{StaticResource Accent}"
                                   FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="{Binding Modal.Message}" Foreground="{StaticResource Fg}"
                                   TextWrapping="Wrap" Margin="0,8,0,10" />
                        <Border x:Name="ModalInputBorder" Background="#1A1A1A" CornerRadius="6" Padding="6"
                                Visibility="{Binding Modal.ShowInput, Converter={StaticResource BoolVis}}">
                            <TextBox x:Name="ModalInput" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource Fg}"
                                     Text="{Binding Modal.InputValue, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button Content="Cancel" Padding="12,5" Margin="0,0,8,0" Click="OnModalCancel"
                                    Background="#2A2A2A" Foreground="{StaticResource Fg}" BorderThickness="0" />
                            <Button x:Name="ModalConfirm" Content="{Binding Modal.ConfirmText}" Padding="12,5"
                                    Click="OnModalConfirm" Background="{StaticResource Accent}"
                                    Foreground="#121212" BorderThickness="0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
